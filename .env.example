# =============================================================================
# Patyka Tarot — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the real values.
# NEVER commit .env.local or .env.production — they contain secrets.
# =============================================================================

# --- PostgreSQL (Drizzle ORM) ---
DATABASE_URL=postgresql://user:password@localhost:5432/patyka

# --- Wompi (Colombia) ---
# Sandbox keys from https://comercios.wompi.co/
WOMPI_PUBLIC_KEY=pk_test_xxxxxxxx
WOMPI_PRIVATE_KEY=sk_test_xxxxxxxx
# Events key from Wompi dashboard → Configuración → Eventos
WOMPI_EVENTS_KEY=test_events_xxxxxxxx

# --- Google Calendar API ---
# Obtain via Google Cloud Console → Calendar API → OAuth 2.0
# One-time CLI script gets the refresh token (no consent UI needed).
GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxx
GOOGLE_REFRESH_TOKEN=1//xxxxxxxx

# --- Resend (Transactional Email) ---
# API key from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxx

# --- App ---
# Base URL for redirect URLs and metadata
NEXT_PUBLIC_BASE_URL=http://localhost:3000
